# --- Supabase (projet cloud) ---------------------------------------------
# Dashboard : https://supabase.com/dashboard/project/wqredfgewyngzcdvvptg
NEXT_PUBLIC_SUPABASE_URL=https://wqredfgewyngzcdvvptg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres (Drizzle, côté serveur) ------------------------------------
# Connection string Supabase (Session pooler recommandé pour Drizzle).
# Récupérable dans Project Settings > Database > Connection string > URI.
# Format : postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=

# --- Supabase local (CLI / docker) ---------------------------------------
# Renseigné automatiquement par `supabase start`. Décommenter pour bosser
# en local au lieu du cloud.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- App -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Resend) ------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
# Adresse expéditrice — doit être sur un domaine vérifié dans Resend.
EMAIL_FROM="Parade OS <noreply@parade.fr>"
# "resend" pour envoyer réellement, "console" pour logger en stdout (dev).
EMAIL_DELIVERY=console

# --- Cron jobs (Vercel) --------------------------------------------------
# Secret pour authentifier les invocations des routes /api/cron/*.
# Vercel envoie automatiquement Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# --- Chiffrement des secrets stockés (Google refresh tokens, etc.) -------
# 32 bytes base64. À générer une fois avec :
#   openssl rand -base64 32
# Ne jamais le changer sans plan de rotation : tous les secrets chiffrés
# avec l'ancienne clé deviennent illisibles.
SECRETS_ENC_KEY=

# --- Google OAuth (Drive en v1, puis Gmail/Calendar) ---------------------
# Crée un projet Google Cloud, active l'API Google Drive, configure
# l'écran de consentement OAuth, puis crée un OAuth 2.0 Client ID
# (type "Web application").
#
# Redirect URIs autorisés à ajouter dans la console :
#   - http://localhost:3000/api/google/oauth/callback   (dev)
#   - https://<ton-domaine>/api/google/oauth/callback   (prod)
#
# Scopes requis sur l'écran de consentement :
#   - openid, email, profile
#   - https://www.googleapis.com/auth/drive.file
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# API key Google Cloud (différente du client OAuth) utilisée par le
# Google Picker côté client. Optionnelle mais recommandée pour ne pas
# se faire rate-limiter en prod.
#
# Console > APIs & Services > Credentials > Create credentials > API key
# → restreindre à l'API "Google Picker API" et aux référents HTTP de
#   ton domaine (`http://localhost:3000/*`, `https://<prod>/*`).
NEXT_PUBLIC_GOOGLE_API_KEY=
